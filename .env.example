# ── App ─────────────────────────────────────────────────────────
# REQUIRED: Application port
PORT=3000

# ── MongoDB ─────────────────────────────────────────────────────
# optional — defaults to mongodb://localhost:27017/boilerplate_db?replicaSet=rs0
# Uncomment and customize if your MongoDB is elsewhere:
# MONGODB_URI=mongodb://localhost:27017/boilerplate_db?replicaSet=rs0

# ── Auth: JWT ───────────────────────────────────────────────────
# optional in dev (INSECURE default is applied with a warning)
# ⚠️ Set a strong secret in production (min 32 chars)!
# JWT_SECRET=your-super-secret-key-min-32-chars
# optional (defaults below)
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_ISSUER=api-nominas
JWT_AUDIENCE=api-nominas

# ── Auth: Magic Link ────────────────────────────────────────────
# optional
MAGIC_LINK_ENABLED=true
MAGIC_LINK_TOKEN_TTL=300

# ── Auth: OAuth (Optional — leave empty if not used) ────────────
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# ── Auth: Argon2 ────────────────────────────────────────────────
# optional
ARGON2_TYPE=2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── Auth: 2FA ───────────────────────────────────────────────────
# optional
TWO_FACTOR_ISSUER=MyApp
TWO_FACTOR_ALGORITHM=SHA1
TWO_FACTOR_DIGITS=6
TWO_FACTOR_PERIOD=30
TWO_FACTOR_BACKUP_CODES_COUNT=10
TWO_FACTOR_BACKUP_CODES_LENGTH=10

# ── Auth: Passkeys ──────────────────────────────────────────────
# optional
PASSKEYS_RP_ID=localhost
PASSKEYS_RP_NAME=MyApp
PASSKEYS_RP_ORIGIN=http://localhost:3000

# ── Playwright ──────────────────────────────────────────────────
# optional
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_RETRIES=3
# PLAYWRIGHT_BROWSERS_PATH=/opt/playwright/browsers   # uncomment if custom path

# ── Inngest ─────────────────────────────────────────────────────
# ⚠️ REQUIRED if InngestModule is used
INNGEST_EVENT_KEY=your_event_key
INNGEST_SIGNING_KEY=your_signing_key
# optional
INNGEST_BASE_URL=https://inngest.treborjs-dev.online/

# ── Resend ──────────────────────────────────────────────────────
# ⚠️ REQUIRED if email sending is needed (app warns if missing)
# RESEND_API_KEY=
# optional
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=My App
# RESEND_REPLY_TO=

# ── AI Providers (Optional — each provider works only if its key is set) ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# MINIMAX_API_KEY=

# ── Dynamic Schema ──────────────────────────────────────────────
# Set to 'true' to skip Mongoose model registration and rehydration
# DYNAMIC_SCHEMA_LEGACY=false

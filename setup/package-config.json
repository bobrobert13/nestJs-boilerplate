{
  "packages": [
    {
      "id": "ai",
      "name": "@common/ai",
      "description": "AI Providers wrapper - OpenAI, Anthropic, Google Gemini, Moonshot, MiniMax",
      "path": "packages/ai",
      "selected": true,
      "dependencies": {
        "axios": "^1.7.9"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": [
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API key for GPT models",
          "required": false
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "description": "Anthropic API key for Claude models",
          "required": false
        },
        {
          "name": "GOOGLE_API_KEY",
          "description": "Google API key for Gemini models",
          "required": false
        },
        {
          "name": "MOONSHOT_API_KEY",
          "description": "Moonshot API key for Kimi models",
          "required": false
        },
        {
          "name": "MINIMAX_API_KEY",
          "description": "MiniMax API key",
          "required": false
        }
      ]
    },
    {
      "id": "auth",
      "name": "@common/auth",
      "description": "Authentication module with JWT, Magic Links, OAuth, 2FA, and Passkeys",
      "path": "packages/auth",
      "selected": true,
      "dependencies": {
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/passport": "^11.0.4",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "argon2": "^0.31.0",
        "otplib": "^12.0.1",
        "qrcode": "^1.5.4",
        "@simplewebauthn/server": "^10.0.0",
        "uuid": "^11.0.0"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": [
        {
          "name": "JWT_SECRET",
          "description": "JWT secret key (min 32 characters)",
          "required": true,
          "default": "change-me-super-secret-key-min-32-chars"
        },
        {
          "name": "JWT_ACCESS_TOKEN_TTL",
          "description": "JWT access token TTL in seconds",
          "required": false,
          "default": "900"
        },
        {
          "name": "JWT_REFRESH_TOKEN_TTL",
          "description": "JWT refresh token TTL in seconds",
          "required": false,
          "default": "604800"
        },
        {
          "name": "JWT_ISSUER",
          "description": "JWT issuer claim",
          "required": false,
          "default": "api-nominas"
        },
        {
          "name": "JWT_AUDIENCE",
          "description": "JWT audience claim",
          "required": false,
          "default": "api-nominas"
        },
        {
          "name": "MAGIC_LINK_ENABLED",
          "description": "Enable magic link authentication",
          "required": false,
          "default": "true"
        },
        {
          "name": "MAGIC_LINK_TOKEN_TTL",
          "description": "Magic link token TTL in seconds",
          "required": false,
          "default": "300"
        },
        {
          "name": "OAUTH_GOOGLE_CLIENT_ID",
          "description": "Google OAuth client ID",
          "required": false,
          "default": ""
        },
        {
          "name": "OAUTH_GOOGLE_CLIENT_SECRET",
          "description": "Google OAuth client secret",
          "required": false,
          "default": ""
        },
        {
          "name": "OAUTH_GITHUB_CLIENT_ID",
          "description": "GitHub OAuth client ID",
          "required": false,
          "default": ""
        },
        {
          "name": "OAUTH_GITHUB_CLIENT_SECRET",
          "description": "GitHub OAuth client secret",
          "required": false,
          "default": ""
        },
        {
          "name": "ARGON2_TYPE",
          "description": "Argon2 variant (2 = Argon2id)",
          "required": false,
          "default": "2"
        },
        {
          "name": "ARGON2_MEMORY_COST",
          "description": "Argon2 memory cost",
          "required": false,
          "default": "65536"
        },
        {
          "name": "ARGON2_TIME_COST",
          "description": "Argon2 time cost",
          "required": false,
          "default": "3"
        },
        {
          "name": "ARGON2_PARALLELISM",
          "description": "Argon2 parallelism",
          "required": false,
          "default": "4"
        },
        {
          "name": "TWO_FACTOR_ISSUER",
          "description": "Two-factor authentication issuer",
          "required": false,
          "default": "MyApp"
        },
        {
          "name": "PASSKEYS_RP_ID",
          "description": "Passkeys relying party ID",
          "required": false,
          "default": "localhost"
        },
        {
          "name": "PASSKEYS_RP_NAME",
          "description": "Passkeys relying party name",
          "required": false,
          "default": "MyApp"
        },
        {
          "name": "PASSKEYS_RP_ORIGIN",
          "description": "Passkeys relying party origin",
          "required": false,
          "default": "http://localhost:3000"
        }
      ]
    },
    {
      "id": "database",
      "name": "@common/database",
      "description": "MongoDB connection module with retry logic and transactions",
      "path": "packages/database",
      "selected": true,
      "dependencies": {
        "mongoose": "^9.4.1"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": [
        {
          "name": "MONGODB_URI",
          "description": "MongoDB connection string",
          "required": true,
          "default": "mongodb://localhost:27017/boilerplate_db"
        }
      ]
    },
    {
      "id": "http",
      "name": "@common/http",
      "description": "HTTP client with axios, image optimization with sharp",
      "path": "packages/http",
      "selected": true,
      "dependencies": {
        "axios": "^1.15.2",
        "sharp": "^0.33.5"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": []
    },
    {
      "id": "playwright",
      "name": "@common/playwright",
      "description": "Browser automation for web scraping",
      "path": "packages/playwright",
      "selected": false,
      "dependencies": {
        "playwright": "^1.59.1"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": [
        {
          "name": "PLAYWRIGHT_HEADLESS",
          "description": "Run Playwright in headless mode",
          "required": false,
          "default": "true"
        },
        {
          "name": "PLAYWRIGHT_TIMEOUT",
          "description": "Playwright timeout in milliseconds",
          "required": false,
          "default": "30000"
        },
        {
          "name": "PLAYWRIGHT_RETRIES",
          "description": "Number of Playwright retries",
          "required": false,
          "default": "3"
        }
      ]
    },
    {
      "id": "resend",
      "name": "@common/resend",
      "description": "Email service via Resend API with newsletter module",
      "path": "packages/resend",
      "selected": false,
      "dependencies": {
        "resend": "^4.0.0"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": [
        {
          "name": "RESEND_API_KEY",
          "description": "Resend API key",
          "required": false,
          "default": ""
        },
        {
          "name": "RESEND_FROM_EMAIL",
          "description": "Default from email address",
          "required": false,
          "default": ""
        },
        {
          "name": "RESEND_FROM_NAME",
          "description": "Default from name",
          "required": false,
          "default": "My App"
        },
        {
          "name": "RESEND_REPLY_TO",
          "description": "Default reply-to address",
          "required": false,
          "default": ""
        }
      ]
    },
    {
      "id": "serve-static",
      "name": "@common/serve-static",
      "description": "Static file serving with EJS templates and TailwindCSS CDN",
      "path": "packages/serve-static",
      "selected": false,
      "dependencies": {
        "ejs": "^3.1.10"
      },
      "peerDependencies": {
        "@nestjs/common": "^10.0.0 || ^11.0.0",
        "@nestjs/core": "^10.0.0 || ^11.0.0"
      },
      "envVars": []
    },
    {
      "id": "common",
      "name": "@common/common",
      "description": "Common utilities - base adapter interface, database exception filter",
      "path": "packages/common",
      "selected": true,
      "dependencies": {},
      "peerDependencies": {},
      "envVars": []
    }
  ],
  "app": {
    "name": "nominas",
    "port": 3000,
    "selectedEnvVars": [
      {
        "name": "PORT",
        "description": "Application port",
        "required": false,
        "default": "3000"
      }
    ]
  }
}

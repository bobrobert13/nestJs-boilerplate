{
  "ignorePatterns": [
    {
      "pattern": "^https?://"
    },
    {
      "pattern": "^mailto:"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^assets/",
      "replacement": "{{BASEURL}}/assets/"
    }
  ],
  "httpHeaders": [],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 2,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 201, 204, 301, 302, 307, 308]
}

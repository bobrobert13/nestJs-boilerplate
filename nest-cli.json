{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/nominas/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "webpackConfigPath": "webpack.config.js",
    "tsConfigPath": "apps/nominas/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/nominas",
  "projects": {
    "nominas": {
      "type": "application",
      "root": "apps/nominas",
      "entryFile": "main",
      "sourceRoot": "apps/nominas/src",
      "compilerOptions": {
        "tsConfigPath": "apps/nominas/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "packages/database",
      "entryFile": "index",
      "sourceRoot": "packages/database/src",
      "compilerOptions": {
        "tsConfigPath": "packages/database/tsconfig.json"
      }
    },
    "playwright": {
      "type": "library",
      "root": "packages/playwright",
      "entryFile": "index",
      "sourceRoot": "packages/playwright/src",
      "compilerOptions": {
        "tsConfigPath": "packages/playwright/tsconfig.json"
      }
    },
    "common": {
      "type": "library",
      "root": "packages/common",
      "entryFile": "index",
      "sourceRoot": "packages/common/src",
      "compilerOptions": {
        "tsConfigPath": "packages/common/tsconfig.json"
      }
    },
    "http": {
      "type": "library",
      "root": "packages/http",
      "entryFile": "index",
      "sourceRoot": "packages/http/src",
      "compilerOptions": {
        "tsConfigPath": "packages/http/tsconfig.json"
      }
    },
    "serve-static": {
      "type": "library",
      "root": "packages/serve-static",
      "entryFile": "index",
      "sourceRoot": "packages/serve-static/src",
      "compilerOptions": {
        "tsConfigPath": "packages/serve-static/tsconfig.json"
      }
    },
    "ai": {
      "type": "library",
      "root": "packages/ai",
      "entryFile": "index",
      "sourceRoot": "packages/ai/src",
      "compilerOptions": {
        "tsConfigPath": "packages/ai/tsconfig.json"
      }
    },
    "documents": {
      "type": "library",
      "root": "packages/documents",
      "entryFile": "index",
      "sourceRoot": "packages/documents/src",
      "compilerOptions": {
        "tsConfigPath": "packages/documents/tsconfig.json"
      }
    }
  }
}

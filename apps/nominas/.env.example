# Auth - JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_ISSUER=api-nominas
JWT_AUDIENCE=api-nominas

# Auth - Magic Link
MAGIC_LINK_ENABLED=true
MAGIC_LINK_TOKEN_TTL=300

# Auth - OAuth (Optional)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Auth - Password Hashing (Argon2)
ARGON2_TYPE=2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Auth - Two Factor (2FA)
TWO_FACTOR_ISSUER=MyApp
TWO_FACTOR_ALGORITHM=SHA1
TWO_FACTOR_DIGITS=6
TWO_FACTOR_PERIOD=30
TWO_FACTOR_BACKUP_CODES_COUNT=10
TWO_FACTOR_BACKUP_CODES_LENGTH=10

# Auth - Passkeys (WebAuthn)
PASSKEYS_RP_ID=localhost
PASSKEYS_RP_NAME=MyApp
PASSKEYS_RP_ORIGIN=http://localhost:3000

# Auth - LEGACY (DEPRECATED: remove before next minor release)
# LEGACY_AUTH_MODE=false

# Network
# Integer hops before req.ip reflects the client. Set behind the number of
# reverse proxies (e.g., 1 for one nginx in front).
# TRUST_PROXY_HOPS=1

# SSRF guard - CSV of CIDRs that bypass the deny-list. Use sparingly.
# SSRF_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16

# Dynamic schema - CSV of collection names allowed as `ref` in schemas.
# ALLOWED_REFS=usuarios,productos

# Passkeys - challenge TTL in ms. Floor 300000; non-numeric → default.
# PASSKEY_CHALLENGE_TTL_MS=600000

# Playwright - only set to "true" to disable Chromium sandboxing (containers).
# Logs a WARN when enabled.
# PLAYWRIGHT_NO_SANDBOX=false